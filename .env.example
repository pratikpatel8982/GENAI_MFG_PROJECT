# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── Firebase ──────────────────────────────────────────────────────────────────
# Base64-encode your Firebase service-account JSON, then paste the string here:
#   Linux/Mac:  base64 -w 0 serviceAccountKey.json
#   Windows PS: [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))
FIREBASE_CREDENTIALS_B64=your_base64_encoded_firebase_service_account_json

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:5000
